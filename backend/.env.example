# ── Storj S3-compatible gateway ────────────────────────────────────────────────
# Gateway URL for your Storj project (e.g. https://gateway.storjshare.io)
STORJ_ENDPOINT=https://gateway.storjshare.io
# S3-compatible access key generated in the Storj console
STORJ_ACCESS_KEY=your-storj-access-key
# Corresponding secret key
STORJ_SECRET_KEY=your-storj-secret-key
# Bucket name created in your Storj project
STORJ_BUCKET=your-bucket-name

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./degenome.db

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
